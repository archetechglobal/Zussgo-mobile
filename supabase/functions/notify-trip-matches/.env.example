# supabase/functions/notify-trip-matches/.env.example
# Copy values to your Supabase project → Settings → Edge Functions → Secrets

# Auto-injected by Supabase runtime — do NOT set manually
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Perplexity API key — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Cloud Messaging
# Project ID from Firebase console → Project settings → General
FCM_PROJECT_ID=zussgo-xxxxx
# Server key (Bearer token) from Firebase console → Project settings → Cloud Messaging → Server key
FCM_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
